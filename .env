# =============================================================================
# MoneyTalks — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in every value.
# NEVER commit .env to version control (it is in .gitignore).
#
# Find your Supabase values at:
#   https://supabase.com/dashboard/project/<your-project>/settings/api
# =============================================================================

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace-with-a-random-32-byte-hex-string

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://jhnjhyhovdxrlscwjzsh.supabase.co

# Dashboard → Project Settings → API → service_role (secret)
# WARNING: This key bypasses RLS. Never expose it to the browser.
SUPABASE_SERVICE_KEY=sb_secret_5O6fFs3-eCYa_HL2fg7I1g_XxJxO-ML

# ── ML Model ──────────────────────────────────────────────────────────────────
# Local path where the active .pkl is cached after download from Supabase Storage
MODEL_PATH=models/active/model.pkl

# Minimum confidence to accept a detection (0.0 to 1.0)
CONFIDENCE_THRESHOLD=0.75

# ── Camera ────────────────────────────────────────────────────────────────────
# How often the browser captures a frame (milliseconds)
CAPTURE_INTERVAL_MS=1000

# ── Rate limiting (production: use Redis) ─────────────────────────────────────
# Development: REDIS_URL=memory://
# Production:  REDIS_URL=redis://localhost:6379/0
REDIS_URL=memory://

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
